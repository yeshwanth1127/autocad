# Polygon Inventory Properties
DecimalPlaces=3

# Sprinkler / shaft defaults (meters and m2). Ship Properties.config beside the plugin DLL.
# Center-to-center sprinkler spacing (agent schema band ~1.5-4.6 m).
SprinklerSpacingM=3
# Sprinkler-to-boundary distance: inward inset + default max boundary gap for placement.
SprinklerToBoundaryDistanceM=1.5
# Plan-view radius of the sprinkler head symbol (meters), used when placing branch reducers on the head circle.
# If omitted, SprinklerToBoundaryDistanceM is used.
SprinklerHeadRadiusM=0.52
# Maximum floor area one shaft may serve (m2).
ShaftMaxServiceAreaM2=3000
