        private void PopulateInventoryGrid(List<PolygonInfo> polygons)
        {
            if (polygons == null)
            {
                inventoryGrid.ItemsSource = null;
                inventoryGrid.Visibility = System.Windows.Visibility.Collapsed;
                return;
            }

            var items = new List<InventoryRow>();
            int idx = 1;
            int decimalPlaces = GetDecimalPlaces();
            string format = "F" + decimalPlaces;
            foreach (var poly in polygons)
            {
                if (!poly.IsClosed)
                    continue; // Exclude open polygons
                items.Add(new InventoryRow
                {
                    Index = idx++,
                    RoomType = string.IsNullOrWhiteSpace(poly.RoomType) ? string.Empty : poly.RoomType,
                    Layer = poly.Layer,
                    Color = poly.Color,
                    Area = double.Parse(poly.Area.ToString(format)),
                    Perimeter = double.Parse(poly.Perimeter.ToString(format)),
                    Height = poly.Height
                });
            }
            inventoryGrid.ItemsSource = items;
            inventoryGrid.Visibility = System.Windows.Visibility.Visible;
        }

        public class InventoryRow
        {
            public int Index { get; set; }
            public string RoomType { get; set; }
            public string Layer { get; set; }
            public string Color { get; set; }
            public double Area { get; set; }
            public double Perimeter { get; set; }
            public double Height { get; set; }
        }
