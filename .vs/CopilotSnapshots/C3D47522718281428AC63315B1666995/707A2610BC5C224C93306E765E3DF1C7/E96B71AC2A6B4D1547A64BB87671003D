        private void BtnClearHatch_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                var doc = Autodesk.AutoCAD.ApplicationServices.Application.DocumentManager.MdiActiveDocument;
                var db = doc.Database;
                using (var tr = db.TransactionManager.StartTransaction())
                {
                    BlockTable bt = (BlockTable)tr.GetObject(db.BlockTableId, OpenMode.ForRead);
                    BlockTableRecord btr = (BlockTableRecord)tr.GetObject(bt[BlockTableRecord.ModelSpace], OpenMode.ForWrite);
                    var toRemove = new List<ObjectId>();
                    foreach (ObjectId objId in btr)
                    {
                        var ent = tr.GetObject(objId, OpenMode.ForRead) as Entity;
                        if (ent is Hatch)
                        {
                            toRemove.Add(objId);
                        }
                    }
                    foreach (var id in toRemove)
                    {
                        var ent = tr.GetObject(id, OpenMode.ForWrite);
                        ent.Erase();
                    }
                    tr.Commit();
                }
                MessageBox.Show("All hatches have been removed.", "Hatch Cleared", MessageBoxButton.OK, MessageBoxImage.Information);
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Failed to clear hatches: {ex.Message}", "Error", MessageBoxButton.OK, MessageBoxImage.Error);
            }
        }

        private void BtnClearInventory_Click(object sender, RoutedEventArgs e)
        {
            Class1.PolygonInventory.Clear();
            inventoryGrid.ItemsSource = null;
