        [CommandMethod("WindowSelectPolygons")]
        public void WindowSelectPolygons()
        {
            var ed = Autodesk.AutoCAD.ApplicationServices.Application.DocumentManager.MdiActiveDocument.Editor;
            var db = Autodesk.AutoCAD.ApplicationServices.Application.DocumentManager.MdiActiveDocument.Database;
            // Prompt for window selection
            PromptPointResult ppr1 = ed.GetPoint("Select first corner of window: ");
            if (ppr1.Status != PromptStatus.OK) return;
            PromptCornerOptions pco = new PromptCornerOptions("Select opposite corner: ", ppr1.Value);
            PromptPointResult ppr2 = ed.GetCorner(pco);
            if (ppr2.Status != PromptStatus.OK) return;
            Point3d pt1 = ppr1.Value;
            Point3d pt2 = ppr2.Value;
            // Validate points are not identical and are valid for window selection
            if (pt1 == pt2)
            {
                ed.WriteMessage("\nInvalid window: points are identical. Please select two distinct corners.");
                return;
            }
            double minDist = 1e-6; // adjust as needed
            if (pt1.DistanceTo(pt2) < minDist)
            {
                ed.WriteMessage("\nInvalid window: points are too close. Please select a larger window.");
                return;
            }
            // Always use min/max for each coordinate to ensure valid Extents3d
            double minX = Math.Min(pt1.X, pt2.X);
            double minY = Math.Min(pt1.Y, pt2.Y);
            double minZ = Math.Min(pt1.Z, pt2.Z);
            double maxX = Math.Max(pt1.X, pt2.X);
            double maxY = Math.Max(pt1.Y, pt2.Y);
            double maxZ = Math.Max(pt1.Z, pt2.Z);
            Point3d minPt = new Point3d(minX, minY, minZ);
            Point3d maxPt = new Point3d(maxX, maxY, maxZ);
            Extents3d window = new Extents3d(minPt, maxPt);

            // Centralized scan
            var polygons = GetPolygonsFromModelSpace(db, window);
            Window win = new PolygonInventoryWindow(polygons);
            win.Title = "Inventory in Window";
            win.Show();
        }

        private static bool IsPointInWindow(Extents3d window, Point3d pt)
        {
            double minX = Math.Min(window.MinPoint.X, window.MaxPoint.X);
            double maxX = Math.Max(window.MinPoint.X, window.MaxPoint.X);
            double minY = Math.Min(window.MinPoint.Y, window.MaxPoint.Y);
            double maxY = Math.Max(window.MinPoint.Y, window.MaxPoint.Y);
            return pt.X >= minX && pt.X <= maxX && pt.Y >= minY && pt.Y <= maxY;
        }

        private static List<Point2d> GetVertices(Polyline pl)
        {
            var verts = new List<Point2d>();
            for (int i = 0; i < pl.NumberOfVertices; i++)
                verts.Add(pl.GetPoint2dAt(i));
            return verts;
        }

